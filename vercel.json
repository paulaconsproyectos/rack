{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron-weekly",
      "schedule": "0 18 * * 5"
    },
    {
      "path": "/api/cron-review-reminders",
      "schedule": "0 */2 * * *"
    }
  ]
}
